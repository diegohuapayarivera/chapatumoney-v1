              "raw": "{\n  \"nombre\": \"DJ Cumbiambero PRO\",\n  \"genero\": \"Cumbia Fusión\",\n  \"bio\": \"Bio actualizada con más experiencia\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "artists", "{{artistId}}"]
            }
          }
        },
        {
          "name": "Eventos del Artista",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}/events?page=0&size=10",
              "host": ["{{baseUrl}}"], "path": ["api", "artists", "{{artistId}}", "events"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Seguir Artista ❤️",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}/follow",
              "host": ["{{baseUrl}}"], "path": ["api", "artists", "{{artistId}}", "follow"]
            },
            "description": "Devuelve 409 si ya lo sigues."
          }
        },
        {
          "name": "Dejar de Seguir Artista 💔",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}/follow",
              "host": ["{{baseUrl}}"], "path": ["api", "artists", "{{artistId}}", "follow"]
            }
          }
        }
      ]
    },
    {
      "name": "🎉 Eventos",
      "item": [
        {
          "name": "Listar Eventos (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["api", "events"],
              "query": [
                { "key": "ciudad",      "value": "Lima",       "disabled": true },
                { "key": "genero",      "value": "Cumbia",     "disabled": true },
                { "key": "fecha_desde", "value": "2025-01-01", "disabled": true },
                { "key": "fecha_hasta", "value": "2025-12-31", "disabled": true },
                { "key": "q",          "value": "rock",        "disabled": true },
                { "key": "page",       "value": "0" },
                { "key": "size",       "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Crear Evento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('eventId', body.id);",
                  "    pm.test('Evento creado', () => pm.response.to.have.status(201));",
                  "    console.log('eventId guardado:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Festival Cumbia Lima 2025\",\n  \"descripcion\": \"El festival de cumbia más grande del Perú\",\n  \"lugar\": \"Estadio San Marcos\",\n  \"ciudad\": \"Lima\",\n  \"fechaInicio\": \"2025-08-15T20:00:00-05:00\",\n  \"fechaFin\": \"2025-08-16T02:00:00-05:00\",\n  \"imagenUrl\": \"https://picsum.photos/seed/event1/800/400\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events",
              "host": ["{{baseUrl}}"], "path": ["api", "events"]
            },
            "description": "Requiere ser organizador. El evento se crea en estado `draft`."
          }
        },
        {
          "name": "Obtener Evento (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"]
            }
          }
        },
        {
          "name": "Actualizar Evento",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Festival Cumbia Lima 2025 — Edición Especial\",\n  \"descripcion\": \"Descripción actualizada\",\n  \"ciudad\": \"Lima\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"]
            }
          }
        },
        {
          "name": "Publicar Evento (draft → published)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmar\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/publish",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "publish"]
            },
            "description": "⚠️ El evento debe tener al menos un TicketType antes de publicar."
          }
        },
        {
          "name": "Cancelar Evento",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"]
            },
            "description": "⚠️ Falla con 409 si hay órdenes confirmadas."
          }
        },
        {
          "name": "Agregar Artista al Evento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"artistId\": \"{{artistId}}\",\n  \"orden\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/artists",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "artists"]
            }
          }
        },
        {
          "name": "Quitar Artista del Evento",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/artists/{{artistId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "artists", "{{artistId}}"]
            }
          }
        }
      ]
    },
    {
