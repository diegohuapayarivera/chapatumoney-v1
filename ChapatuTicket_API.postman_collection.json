              "raw": "{\n  \"ticketTypeId\": \"{{ticketTypeId}}\",\n  \"cantidad\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "7. Confirmar Orden",
          "request": {
            "method": "POST",
            "header": [],
