{
  "info": {
    "name": "ChapatuTicket API",
    "description": "Colección completa de la API REST de ChapatuTicket — Spring Boot 4 + Supabase.\n\n**Setup:**\n1. Registra un usuario en tu frontend (Supabase Auth)\n2. Copia el JWT desde Supabase Dashboard > Authentication > Users > tu usuario > Copy token\n3. Pega el token en la variable `token` (botón Edit en la colección)\n4. Ejecuta '🔐 Auth > Mi Perfil' para verificar\n\nBase URL: `{{baseUrl}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8080",  "type": "string" },
    { "key": "token",          "value": "PEGA_AQUI_TU_JWT",       "type": "string" },
    { "key": "userId",         "value": "",                        "type": "string" },
    { "key": "organizerId",    "value": "",                        "type": "string" },
    { "key": "artistId",       "value": "",                        "type": "string" },
    { "key": "eventId",        "value": "",                        "type": "string" },
    { "key": "ticketTypeId",   "value": "",                        "type": "string" },
    { "key": "orderId",        "value": "",                        "type": "string" },
    { "key": "ticketId",       "value": "",                        "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Mi Perfil (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('userId', body.id);",
                  "    if (body.organizerId) pm.collectionVariables.set('organizerId', body.organizerId);",
                  "    if (body.artistId)    pm.collectionVariables.set('artistId', body.artistId);",
                  "    pm.test('Perfil obtenido correctamente', () => pm.response.to.have.status(200));",
                  "    console.log('userId guardado:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "description": "Retorna el perfil completo del usuario autenticado, incluyendo roles (isOrganizer, isArtist).\n\n✅ Guarda automáticamente userId, organizerId y artistId en las variables."
          }
        }
      ]
    },
    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "Obtener Usuario (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}"]
            },
            "description": "Endpoint público — no requiere JWT."
          }
        },
        {
          "name": "Actualizar mi Perfil",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Mi Nombre Actualizado\",\n  \"avatarUrl\": \"https://i.pravatar.cc/150?img=3\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}"]
            },
            "description": "Solo puedes editar tu propio perfil (valida que el token coincide con el ID)."
          }
        },
        {
          "name": "Artistas que sigo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me/following?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["api", "users", "me", "following"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🏢 Organizadores",
      "item": [
        {
          "name": "Crear Perfil de Organizador",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('organizerId', body.id);",
                  "    pm.test('Organizador creado', () => pm.response.to.have.status(201));",
                  "    console.log('organizerId guardado:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Mi Promotora Musical\",\n  \"descripcion\": \"Organizamos los mejores eventos de Lima\",\n  \"logoUrl\": \"https://picsum.photos/seed/org1/200\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/organizers",
              "host": ["{{baseUrl}}"], "path": ["api", "organizers"]
            },
            "description": "Un usuario solo puede tener UN perfil de organizador (devuelve 409 si ya existe)."
          }
        },
        {
          "name": "Obtener Organizador (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/organizers/{{organizerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "organizers", "{{organizerId}}"]
            }
          }
        },
        {
          "name": "Actualizar Organizador",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Promotora Actualizada\",\n  \"descripcion\": \"Nueva descripción con más detalles\",\n  \"logoUrl\": \"https://picsum.photos/seed/org2/200\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/organizers/{{organizerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "organizers", "{{organizerId}}"]
            }
          }
        },
        {
          "name": "Eventos del Organizador",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/organizers/{{organizerId}}/events?page=0&size=10",
              "host": ["{{baseUrl}}"], "path": ["api", "organizers", "{{organizerId}}", "events"],
              "query": [
                { "key": "estado", "value": "published", "disabled": true, "description": "draft | published | cancelled" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🎤 Artistas",
      "item": [
        {
          "name": "Listar Artistas (búsqueda)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/artists?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["api", "artists"],
              "query": [
                { "key": "q",      "value": "rock",    "disabled": true, "description": "buscar por nombre" },
                { "key": "genero", "value": "cumbia",  "disabled": true, "description": "filtrar por género" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Crear Perfil de Artista",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('artistId', body.id);",
                  "    pm.test('Artista creado', () => pm.response.to.have.status(201));",
                  "    console.log('artistId guardado:', body.id);",
