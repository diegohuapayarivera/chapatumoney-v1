          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "artists", "{{artistId}}"]
            },
            "description": "Con JWT: incluye campo `isFollowing`. Sin JWT: isFollowing = null."
          }
        },
        {
          "name": "Actualizar Artista",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
