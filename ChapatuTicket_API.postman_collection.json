    },
    {
      "name": "🧪 Flujo Completo (ejecutar en orden)",
      "description": "Ejecuta estas requests en orden para probar el flujo completo:\n\n1. 🔐 Mi Perfil — obtiene userId\n2. 🏢 Crear Organizador\n3. 🎤 Crear Artista\n4. 🎉 Crear Evento\n5. 🎫 Crear Tipo de Boleto (General)\n6. 🎉 Publicar Evento\n7. 🎉 Agregar Artista al Evento\n8. 📦 Crear Orden\n9. 📦 Confirmar Orden → genera tickets\n10. 🎟️ Mis Boletos",
      "item": [
        {
          "name": "1. Mi Perfil",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "2. Crear Organizador",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Promotora Demo\",\n  \"descripcion\": \"Organizador de prueba\",\n  \"logoUrl\": \"https://picsum.photos/seed/demo/200\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/organizers", "host": ["{{baseUrl}}"], "path": ["api", "organizers"] }
          }
        },
        {
          "name": "3. Crear Evento (draft)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Evento Demo 2025\",\n  \"descripcion\": \"Evento de prueba\",\n  \"lugar\": \"Centro de Lima\",\n  \"ciudad\": \"Lima\",\n  \"fechaInicio\": \"2025-10-01T20:00:00-05:00\",\n  \"fechaFin\": \"2025-10-02T00:00:00-05:00\",\n  \"imagenUrl\": \"https://picsum.photos/seed/demo-event/800/400\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          }
        },
        {
          "name": "4. Crear Tipo de Boleto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"General\",\n  \"descripcion\": \"Entrada general\",\n  \"precio\": 30.00,\n  \"capacidad\": 200\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/ticket-types",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "ticket-types"]
            }
          }
        },
        {
          "name": "5. Publicar Evento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"confirmar\": true\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/publish",
              "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "publish"]
            }
          }
        },
        {
          "name": "6. Crear Orden",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
