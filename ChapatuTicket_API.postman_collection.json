    {
      "name": "📦 Órdenes",
      "item": [
        {
          "name": "Crear Orden (comprar boletos)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('orderId', body.id);",
                  "    pm.test('Orden creada', () => pm.response.to.have.status(201));",
                  "    console.log('orderId guardado:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketTypeId\": \"{{ticketTypeId}}\",\n  \"cantidad\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"], "path": ["api", "orders"]
            },
            "description": "- Crea una orden en estado `pending`\n- Valida disponibilidad (capacidad - vendidos)\n- Cantidad máxima: 10 por orden"
          }
        },
        {
          "name": "Mis Órdenes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/my?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["api", "orders", "my"],
              "query": [
                { "key": "estado", "value": "confirmed", "disabled": true, "description": "pending | confirmed | cancelled" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Confirmar Orden → Genera Boletos 🎫",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.tickets && body.tickets.length > 0) {",
                  "        pm.collectionVariables.set('ticketId', body.tickets[0].id);",
                  "        console.log('ticketId guardado:', body.tickets[0].id);",
                  "    }",
                  "    pm.test('Orden confirmada y boletos generados', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/confirm",
              "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "confirm"]
            },
            "description": "✅ Cambia estado a `confirmed`, incrementa `vendidos` en el ticket_type y genera N boletos con código QR único."
          }
        },
        {
          "name": "Cancelar Orden",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "cancel"]
            },
            "description": "⚠️ Solo se pueden cancelar órdenes en estado `pending`."
          }
        }
      ]
    },
    {
      "name": "🎟️ Boletos",
      "item": [
        {
          "name": "Mis Boletos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tickets/my?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["api", "tickets", "my"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Ver Boleto (con QR)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketId}}"]
